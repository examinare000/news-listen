# ============================================================
# AudioNews — 環境変数テンプレート
# cp .env.example .env して実際の値を入力する
# .env は絶対にコミットしないこと
# ============================================================

# ── GCP プロジェクト ──────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# Cloud Storage バケット名（{GCP_PROJECT_ID}-podcasts を推奨）
GCP_BUCKET_NAME=your-gcp-project-id-podcasts

# Artifact Registry リポジトリ名
GCP_AR_REPO=audio-news

# ── AI APIs ──────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── アプリ認証 ────────────────────────────────────────────────
# Web/iOS → バックエンド API の認証キー
# 生成方法: openssl rand -hex 32
API_KEY=your-random-api-key-here

# ── ローカル開発 ──────────────────────────────────────────────
# バックエンド API の URL（ローカル開発時）
API_BASE_URL=http://localhost:8080

# Firestore エミュレーター（ローカルテスト時のみ設定）
# FIRESTORE_EMULATOR_HOST=localhost:8088

# Cloud Storage エミュレーター（ローカルテスト時のみ設定）
# STORAGE_EMULATOR_HOST=localhost:9023

# ── Secret Manager 参照名（本番用・変更不要） ─────────────────
SECRET_NAME_API_KEY=audio-news-api-key
SECRET_NAME_GEMINI=audio-news-gemini-key
SECRET_NAME_OPENAI=audio-news-openai-key
